# Google OAuth 설정
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SECRET_KEY=

# DB URL - Supabase/Postgres example
# For Supabase: postgresql+asyncpg://<USER>:<PASS>@db.<PROJECT>.supabase.co:5432/<DB_NAME>?sslmode=require
DATABASE_URL=

# TEST DB URL (used when ENVIRONMENT=test). If set, this overrides DATABASE_URL.
# Example: postgresql+asyncpg://<USER>:<PASS>@db.<PROJECT>.supabase.co:5432/<TEST_DB_NAME>?sslmode=require
TEST_DATABASE_URL=

# Environment Settings
ENVIRONMENT=development
ALLOWED_HOSTS=["localhost","127.0.0.1","*.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Content-Type","Authorization","X-CSRF-Token","Idempotency-Key","X-Test-Now"]

# Google OAuth Additional Settings
GOOGLE_CONF_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_CLIENT_SCOPE=openid email profile

# Server Settings
HOST=0.0.0.0
PORT=8000

# Rate Limits
LOGIN_LIMIT=5/minute
TERMS_LIMIT=20/minute
CONSENTS_LIMIT=10/minute
ME_LIMIT=20/minute
PROTECTED_LIMIT=10/minute

# ----------------------------
# GitHub Copilot (optional)
# ----------------------------
# You can provide credentials either as a single JSON blob or as individual env vars.
# JSON format example:
# {"oauth_token":"gho_xxx","copilot_token":"tid=...;...","copilot_expires_at":1768207139,"copilot_api_endpoint":"https://api.individual.githubcopilot.com"}
# Store secrets in your environment/secret manager — do NOT commit tokens to git.

# Provide full JSON (preferred for convenience):
GITHUB_COPILOT_CREDENTIALS_JSON=

# Or provide fields individually:
GITHUB_OAUTH_TOKEN=
GITHUB_COPILOT_COOKIE=
GITHUB_COPILOT_EXPIRES_AT=
GITHUB_COPILOT_API_ENDPOINT=

# Token request endpoint (default used by scripts)
GITHUB_COPILOT_TOKEN_URL=https://api.github.com/copilot_internal/v2/token

# Client defaults
COPILOT_DEFAULT_MODEL=gpt-5-mini
COPILOT_REQUEST_TIMEOUT=60
