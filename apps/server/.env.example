# Google OAuth 설정
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SECRET_KEY=

# PROD DB URL - used only when ENVIRONMENT=production
# For Supabase: postgresql+asyncpg://<USER>:<PASS>@db.<PROJECT>.supabase.co:5432/<DB_NAME>?sslmode=require
DATABASE_URL=

# DEV DB URL - default for non-production environments
# Example: postgresql+asyncpg://<USER>:<PASS>@db.<PROJECT>.supabase.co:5432/<DEV_DB_NAME>?sslmode=require
DEV_DATABASE_URL=

# TEST DB URL (used only when ENVIRONMENT=test). If unset, DEV_DATABASE_URL is used.
# Example: postgresql+asyncpg://<USER>:<PASS>@db.<PROJECT>.supabase.co:5432/<TEST_DB_NAME>?sslmode=require
TEST_DATABASE_URL=

# Environment Settings
ENVIRONMENT=development
ALLOWED_HOSTS=["localhost","127.0.0.1","*.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Content-Type","Authorization","X-CSRF-Token","Idempotency-Key","X-Test-Now"]
# Frontend Redirect
AUTH_SUCCESS_URL=http://localhost:3000

# Google OAuth Additional Settings
GOOGLE_CONF_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_CLIENT_SCOPE=openid email profile

# Server Settings
HOST=0.0.0.0
PORT=8000

# Rate Limits
LOGIN_LIMIT=5/minute
TERMS_LIMIT=20/minute
CONSENTS_LIMIT=10/minute
ME_LIMIT=20/minute
PROTECTED_LIMIT=10/minute
TOKENS_LIST_LIMIT=30/minute
TOKENS_WRITE_LIMIT=20/minute
TEAMS_WRITE_LIMIT=20/minute
USERS_LEAGUE_UPDATE_LIMIT=10/minute
MCP_SSE_LIMIT=30/minute
MCP_MESSAGES_LIMIT=120/minute

# Provide github oauth info for copilot token exchange and API access
GITHUB_OAUTH_TOKEN=
GITHUB_COPILOT_COOKIE=
GITHUB_COPILOT_EXPIRES_AT=
GITHUB_COPILOT_API_ENDPOINT=

# Token request endpoint (default used by scripts)
GITHUB_COPILOT_TOKEN_URL=https://api.github.com/copilot_internal/v2/token

# Client defaults
COPILOT_DEFAULT_MODEL=gpt-5-mini
COPILOT_REQUEST_TIMEOUT=60
